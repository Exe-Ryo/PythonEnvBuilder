<Window x:Class="PythonEnvBuilder.CommandPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="コマンド例" Height="360" Width="680"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#111827" />

        <TextBlock Grid.Row="1"
                   Text="{Binding Description}"
                   TextWrapping="Wrap"
                   Foreground="#475467"
                   Margin="0,8,0,14" />

        <Border Grid.Row="2"
                Background="#111827"
                CornerRadius="6"
                Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="代表的なコマンド例"
                               Foreground="#D1D5DB"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding CommandText}"
                               Foreground="#67E8F9"
                               FontFamily="Consolas"
                               FontSize="14"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Notes}"
                               Foreground="#E5E7EB"
                               TextWrapping="Wrap"
                               Margin="0,18,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="3"
                Content="閉じる"
                Width="96"
                Height="32"
                HorizontalAlignment="Right"
                Margin="0,14,0,0"
                Click="Close_Click" />
    </Grid>
</Window>
