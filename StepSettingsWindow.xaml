<Window x:Class="PythonEnvBuilder.StepSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工程設定" Height="520" Width="680"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,2" />
            <Setter Property="Margin" Value="4,0,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TitleText"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#111827" />
            <TextBlock x:Name="NotesText"
                       TextWrapping="Wrap"
                       Foreground="#475467"
                       Margin="0,8,0,14" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#D8DEE6"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel x:Name="NoSettingsPanel">
                        <TextBlock Text="この工程に追加設定はありません。"
                                   Foreground="#475467" />
                    </StackPanel>

                    <StackPanel x:Name="DiagnosticsPanel" Visibility="Collapsed">
                        <TextBlock Text="診断結果" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding Diagnostics}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Status}" FontFamily="Consolas" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="#475467" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel x:Name="ProxyPanel" Visibility="Collapsed">
                        <TextBlock Text="Proxy URL" Foreground="#475467" Margin="0,0,0,4" />
                        <TextBox Text="{Binding ProxyUrl, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <CheckBox Content="HTTP_PROXY" IsChecked="{Binding SetHttpProxy}" Margin="0,0,16,0" />
                            <CheckBox Content="HTTPS_PROXY" IsChecked="{Binding SetHttpsProxy}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <RadioButton Content="User" IsChecked="{Binding UseUserTarget}" GroupName="ProxyTarget" Margin="0,0,16,0" />
                            <RadioButton Content="Machine" IsChecked="{Binding UseMachineTarget}" GroupName="ProxyTarget" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="VenvPanel" Visibility="Collapsed">
                        <TextBlock Text="venv名" Foreground="#475467" Margin="0,0,0,4" />
                        <TextBox Text="{Binding VenvName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel x:Name="PackagesPanel" Visibility="Collapsed">
                        <TextBlock Text="導入パッケージ" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding Packages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsSelected}"
                                              Margin="0,0,0,8" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="カスタム Package" Foreground="#475467" Margin="0,10,0,4" />
                        <TextBox Text="{Binding CustomPackage, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel x:Name="RequirementsPanel" Visibility="Collapsed">
                        <TextBlock Text="requirements.txt 操作" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <TextBlock Text="Export はメイン行の実行ボタン、Import はここから実行します。"
                                   Foreground="#475467"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Export" Command="{Binding ExportRequirementsCommand}" />
                            <Button Content="Import" Command="{Binding ImportRequirementsCommand}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2"
                Content="閉じる"
                Width="96"
                HorizontalAlignment="Right"
                Margin="0,14,0,0"
                Click="Close_Click" />
    </Grid>
</Window>
