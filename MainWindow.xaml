<Window x:Class="PythonEnvBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Python Env Builder" Height="820" Width="1180"
        MinHeight="680" MinWidth="1040"
        Background="#F4F6F8">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Margin" Value="4,0,0,0" />
        </Style>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="Background" Value="#EEF2F7" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,3" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="250" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Python 仮想環境構築サポートツール"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#1F2937" />
                <TextBlock Text="{Binding WorkingDirectory}"
                           FontSize="12"
                           Foreground="#667085"
                           Margin="0,3,0,0" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#D8DEE6"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#F9FAFB">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="86" />
                        <ColumnDefinition Width="116" />
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="62" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="項目" FontWeight="SemiBold" Margin="12,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="詳細" FontWeight="SemiBold" Margin="8,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="コマンド" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="実行" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="ステータス" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="5" Text="設定/備考" FontWeight="SemiBold" Margin="8,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="6" Text="設定" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Steps}"
                         BorderThickness="0"
                         Background="White"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EAECF0" BorderThickness="0,0,0,1" Padding="0">
                                <Grid MinHeight="58">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="116" />
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="62" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               TextWrapping="Wrap"
                                               Margin="12,8"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Description}"
                                               Foreground="#475467"
                                               TextWrapping="Wrap"
                                               Margin="8,8"
                                               VerticalAlignment="Center" />

                                    <Button Grid.Column="2"
                                            Style="{StaticResource IconButton}"
                                            Content="?"
                                            Click="ShowCommand_Click"
                                            ToolTip="代表的なコマンド例を表示"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />

                                    <Button Grid.Column="3"
                                            Content="実行"
                                            Command="{Binding Command}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />

                                    <Border Grid.Column="4"
                                            Style="{StaticResource StatusBadge}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="#344054" />
                                    </Border>

                                    <TextBlock Grid.Column="5"
                                               Text="{Binding SettingsSummary}"
                                               Foreground="#475467"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,8"
                                               VerticalAlignment="Center" />

                                    <Button Grid.Column="6"
                                            Style="{StaticResource IconButton}"
                                            Content="⚙"
                                            Click="ShowSettings_Click"
                                            ToolTip="この工程の設定を開く"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#050A12"
                BorderBrush="#1F2937"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,12,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="実行ログ"
                           Foreground="#E5E7EB"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ListBox ItemsSource="{Binding Logs}"
                         Background="#050A12"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="12"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="{Binding Color}" TextWrapping="NoWrap">
                                <Run Text="[" />
                                <Run Text="{Binding Time, Mode=OneWay}" />
                                <Run Text="] " />
                                <Run Text="{Binding Kind, Mode=OneWay}" />
                                <Run Text="  " />
                                <Run Text="{Binding Message, Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
